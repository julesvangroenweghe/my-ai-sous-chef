generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recipe {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String?
  servings    Int      @default(1)
  chef_id     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  components  RecipeComponent[]
  menu_items  MenuItem[]
}

model Ingredient {
  id          String   @id @default(uuid())
  name        String
  unit        String?
  price       Float?
  supplier    String?
  category    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  components  RecipeComponent[]
}

model RecipeComponent {
  id            String     @id @default(uuid())
  recipe_id     String
  ingredient_id String
  quantity      Float
  unit          String?
  recipe        Recipe     @relation(fields: [recipe_id], references: [id])
  ingredient    Ingredient @relation(fields: [ingredient_id], references: [id])
}

model Menu {
  id          String   @id @default(uuid())
  name        String
  date        DateTime?
  event_type  String?
  guest_count Int?
  status      String   @default("draft")
  chef_id     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  items       MenuItem[]
}

model MenuItem {
  id        String  @id @default(uuid())
  menu_id   String
  recipe_id String
  course    String?
  position  Int     @default(0)
  menu      Menu    @relation(fields: [menu_id], references: [id])
  recipe    Recipe  @relation(fields: [recipe_id], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  name        String
  date        DateTime
  location    String?
  guest_count Int?
  event_type  String?
  status      String   @default("planning")
  notes       String?
  chef_id     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(uuid())
  supplier      String
  invoice_number String?
  date          DateTime?
  total_amount  Float?
  status        String   @default("pending")
  ocr_data      Json?
  chef_id       String?
  created_at    DateTime @default(now())
  items         InvoiceItem[]
}

model InvoiceItem {
  id            String  @id @default(uuid())
  invoice_id    String
  ingredient_name String
  quantity      Float?
  unit          String?
  unit_price    Float?
  total_price   Float?
  invoice       Invoice @relation(fields: [invoice_id], references: [id])
}

model ChefProfile {
  id              String   @id @default(uuid())
  user_id         String   @unique
  display_name    String
  cuisine_styles  String[]
  signature_techniques String[]
  preferred_ingredients String[]
  dietary_notes   String?
  experience_years Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}
